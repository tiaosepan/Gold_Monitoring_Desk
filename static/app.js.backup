// 渲染RSS事件
function renderRSSEvents(rssData) {
    if (!rssData) return;
    
    // 政治事件
    const politicalContainer = document.getElementById('political-events');
    if (politicalContainer && rssData.political) {
        politicalContainer.innerHTML = rssData.political.map(event => `
            <div class="event-item" onclick="window.open('${event.link}', '_blank')">
                <div class="event-title">${event.title}</div>
                <div class="event-meta">
                    ${event.source_name}
                    <span class="event-score">${event.score}分</span>
                </div>
            </div>
        `).join('');
    }
    
    // 战争事件
    const warContainer = document.getElementById('war-events');
    if (warContainer && rssData.war) {
        warContainer.innerHTML = rssData.war.map(event => `
            <div class="event-item" onclick="window.open('${event.link}', '_blank')">
                <div class="event-title">${event.title}</div>
                <div class="event-meta">
                    ${event.source_name}
                    <span class="event-score">${event.score}分</span>
                </div>
            </div>
        `).join('');
    }
}

// 加载SGE数据
async function loadSGEData() {
    try {
        const response = await fetch(`${API_BASE}/api/sge/latest?limit=100`);
        const result = await response.json();
        
        if (result.success) {
            state.sgeData = result.data;
            renderSGEDetailChart();
            renderSGETable();
        }
    } catch (error) {
        console.error('加载SGE数据失败:', error);
    }
}

// 渲染SGE详细图表
function renderSGEDetailChart() {
    const chartDom = document.getElementById('sge-detail-chart');
    if (!chartDom) return;
    
    let chart = state.charts.sgeDetailChart;
    if (!chart) {
        chart = echarts.init(chartDom);
        state.charts.sgeDetailChart = chart;
    }
    
    const data = state.sgeData.slice().reverse();
    const times = data.map(d => new Date(d.timestamp).toLocaleString());
    const sgePrices = data.map(d => d.sge_price);
    const intlPrices = data.map(d => d.international_price);
    const premiums = data.map(d => d.premium);
    
    const option = {
        tooltip: {
            trigger: 'axis',
            axisPointer: {
                type: 'cross'
            }
        },
        legend: {
            data: ['SGE价格', '国际金价', '溢价']
        },
        grid: {
            left: '3%',
            right: '4%',
            bottom: '3%',
            containLabel: true
        },
        xAxis: {
            type: 'category',
            boundaryGap: false,
            data: times
        },
        yAxis: [
            {
                type: 'value',
                name: '价格',
                position: 'left'
            },
            {
                type: 'value',
                name: '溢价',
                position: 'right'
            }
        ],
        series: [
            {
                name: 'SGE价格',
                type: 'line',
                data: sgePrices,
                smooth: true
            },
            {
                name: '国际金价',
                type: 'line',
                data: intlPrices,
                smooth: true
            },
            {
                name: '溢价',
                type: 'line',
                yAxisIndex: 1,
                data: premiums,
                smooth: true
            }
        ]
    };
    
    chart.setOption(option);
}

// 渲染SGE表格
function renderSGETable() {
    const tbody = document.querySelector('#sge-table tbody');
    if (!tbody) return;
    
    tbody.innerHTML = state.sgeData.map(d => `
        <tr>
            <td>${new Date(d.timestamp).toLocaleString()}</td>
            <td>${d.sge_price.toFixed(2)}</td>
            <td>${d.international_price.toFixed(2)}</td>
            <td>${d.usdcny_rate.toFixed(4)}</td>
            <td>${d.premium.toFixed(2)}</td>
            <td>${d.premium_percent.toFixed(2)}%</td>
        </tr>
    `).join('');
}

// 加载反转数据
async function loadReversalData() {
    try {
        // 加载最新反转状态
        const latestResponse = await fetch(`${API_BASE}/api/reversal/latest`);
        const latestResult = await latestResponse.json();
        
        if (latestResult.success && latestResult.data) {
            updateReversalStatus(latestResult.data);
        }
        
        // 加载历史记录
        const historyResponse = await fetch(`${API_BASE}/api/reversal/history?limit=100`);
        const historyResult = await historyResponse.json();
        
        if (historyResult.success) {
            state.reversalData = historyResult.data;
            renderReversalTable();
        }
    } catch (error) {
        console.error('加载反转数据失败:', error);
    }
}

// 更新反转状态
function updateReversalStatus(data) {
    // 更新等级显示
    document.getElementById('current-reversal-level').textContent = data.reversal_level;
    
    // 更新条件状态
    const conditions = data.conditions;
    
    updateConditionItem('price', conditions.price);
    updateConditionItem('political', conditions.political);
    updateConditionItem('war', conditions.war);
    updateConditionItem('us10y', conditions.us10y);
}

// 更新条件项
function updateConditionItem(type, isActive) {
    const item = document.getElementById(`condition-${type}`);
    if (!item) return;
    
    const statusEl = item.querySelector('.condition-status');
    
    if (isActive) {
        item.classList.add('active');
        statusEl.textContent = '已满足';
    } else {
        item.classList.remove('active');
        statusEl.textContent = '未满足';
    }
}

// 渲染反转表格
function renderReversalTable() {
    const tbody = document.querySelector('#reversal-table tbody');
    if (!tbody) return;
    
    tbody.innerHTML = state.reversalData.map(d => `
        <tr>
            <td>${new Date(d.timestamp).toLocaleString()}</td>
            <td>${d.reversal_level}</td>
            <td>${d.price_condition ? '✓' : '✗'}</td>
            <td>${d.political_condition ? '✓' : '✗'}</td>
            <td>${d.war_condition ? '✓' : '✗'}</td>
            <td>${d.us10y_condition ? '✓' : '✗'}</td>
        </tr>
    `).join('');
}

