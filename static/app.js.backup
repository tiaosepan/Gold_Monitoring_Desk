// 全局状态管理
const state = {
    currentView: 'overview',
    sgeData: [],
    us10yData: [],
    rssEvents: [],
    reversalData: [],
    systemStatus: null,
    charts: {}
};

// API基础URL
const API_BASE = '';

// 初始化应用
document.addEventListener('DOMContentLoaded', () => {
    initNavigation();
    initAutoRefresh();
    loadOverviewData();
});

// 初始化导航
function initNavigation() {
    const navItems = document.querySelectorAll('.nav-item');
    
    navItems.forEach(item => {
        item.addEventListener('click', (e) => {
            e.preventDefault();
            
            // 更新导航状态
            navItems.forEach(nav => nav.classList.remove('active'));
            item.classList.add('active');
            
            // 切换视图
            const view = item.dataset.view;
            switchView(view);
        });
    });
}

// 切换视图
function switchView(view) {
    // 隐藏所有视图
    document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
    
    // 显示目标视图
    const targetView = document.getElementById(`${view}-view`);
    if (targetView) {
        targetView.classList.add('active');
        state.currentView = view;
        
        // 加载对应视图的数据
        loadViewData(view);
    }
}

// 加载视图数据
function loadViewData(view) {
    switch(view) {
        case 'overview':
            loadOverviewData();
            break;
        case 'sge':
            loadSGEData();
            break;
        case 'reversal':
            loadReversalData();
            break;
        case 'us10y':
            loadUS10YData();
            break;
        case 'rss':
            loadRSSData();
            break;
        case 'system':
            loadSystemStatus();
            break;
    }
}

// 加载总览数据
async function loadOverviewData() {
    try {
        const response = await fetch(`${API_BASE}/api/status`);
        const data = await response.json();
        
        updateOverviewUI(data);
    } catch (error) {
        console.error('加载总览数据失败:', error);
    }
}

// 更新总览UI
function updateOverviewUI(data) {
    // 更新状态卡片 - 使用/api/status的数据结构
    if (data.latest_sample) {
        const premium = data.latest_sample.premium_cny_per_g || 0;
        const londonPrice = data.latest_sample.london_price_usd_per_oz || 0;
        const shfePrice = data.latest_sample.shfe_price_cny_per_g || 0;
        const premiumPercent = shfePrice > 0 ? (premium / shfePrice * 100) : 0;
        
        document.getElementById('sge-premium').textContent = 
            `${premium.toFixed(2)} 元/克`;
        document.getElementById('sge-premium-percent').textContent = 
            `${premiumPercent.toFixed(2)}%`;
        document.getElementById('international-price').textContent = 
            `${londonPrice.toFixed(2)}`;
    }
    
    if (data.us10y_reversal && data.us10y_reversal.latest_sample) {
        const yieldPct = data.us10y_reversal.latest_sample.yield_pct || 0;
        document.getElementById('us10y-yield').textContent = 
            `${yieldPct.toFixed(2)}%`;
    } else {
        document.getElementById('us10y-yield').textContent = '--';
    }
    
    if (data.gold_reversal && data.gold_reversal.latest_sample) {
        const reversal = data.gold_reversal.latest_sample;
        document.getElementById('reversal-level').textContent = 
            `Level ${reversal.signal_level || 0}`;
        
        const conditionTexts = [];
        if (reversal.price_signal) conditionTexts.push('价格');
        if (reversal.political_signal) conditionTexts.push('政治');
        if (reversal.war_signal) conditionTexts.push('战争');
        if (reversal.us10y_signal) conditionTexts.push('美债');
        
        document.getElementById('reversal-conditions').textContent = 
            conditionTexts.length > 0 ? conditionTexts.join(' | ') : '无';
    }
    
    // 渲染SGE图表 - 使用recent_samples数据
    if (data.recent_samples && data.recent_samples.length > 0) {
        renderSGEChartFromStatusData(data.recent_samples);
    }
    
    // 渲染RSS事件
    if (data.gold_reversal && data.gold_reversal.recent_events) {
        renderRSSEventsFromStatusData(data.gold_reversal.recent_events);
    }
    
    // 更新最后更新时间
    updateLastUpdateTime();
}

// 渲染SGE图表
function renderSGEChart(sgeData) {
    const chartDom = document.getElementById('sge-chart');
    if (!chartDom) return;
    
    let chart = state.charts.sgeChart;
    if (!chart) {
        chart = echarts.init(chartDom);
        state.charts.sgeChart = chart;
    }
    
    // 准备数据
    fetch(`${API_BASE}/api/sge/latest?limit=50`)
        .then(res => res.json())
        .then(result => {
            if (result.success && result.data) {
                const data = result.data.reverse();
                
                const times = data.map(d => new Date(d.timestamp).toLocaleTimeString());
                const premiums = data.map(d => d.premium);
                const premiumPercents = data.map(d => d.premium_percent);
                
                const option = {
                    tooltip: {
                        trigger: 'axis',
                        axisPointer: {
                            type: 'cross'
                        }
                    },
                    legend: {
                        data: ['溢价(元/克)', '溢价率(%)']
                    },
                    grid: {
                        left: '3%',
                        right: '4%',
                        bottom: '3%',
                        containLabel: true
                    },
                    xAxis: {
                        type: 'category',
                        boundaryGap: false,
                        data: times
                    },
                    yAxis: [
                        {
                            type: 'value',
                            name: '溢价(元/克)',
                            position: 'left'
                        },
                        {
                            type: 'value',
                            name: '溢价率(%)',
                            position: 'right'
                        }
                    ],
                    series: [
                        {
                            name: '溢价(元/克)',
                            type: 'line',
                            data: premiums,
                            smooth: true,
                            lineStyle: {
                                color: '#667eea'
                            },
                            itemStyle: {
                                color: '#667eea'
                            }
                        },
                        {
                            name: '溢价率(%)',
                            type: 'line',
                            yAxisIndex: 1,
                            data: premiumPercents,
                            smooth: true,
                            lineStyle: {
                                color: '#764ba2'
                            },
                            itemStyle: {
                                color: '#764ba2'
                            }
                        }
                    ]
                };
                
                chart.setOption(option);
            }
        });
}

