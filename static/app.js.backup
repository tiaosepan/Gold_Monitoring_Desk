// 渲染美债表格
function renderUS10YTable() {
    const tbody = document.querySelector('#us10y-table tbody');
    if (!tbody) return;
    
    tbody.innerHTML = state.us10yData.map(d => `
        <tr>
            <td>${new Date(d.timestamp).toLocaleString()}</td>
            <td>${d.yield.toFixed(2)}</td>
        </tr>
    `).join('');
}

// 加载RSS数据
async function loadRSSData() {
    try {
        const category = document.querySelector('input[name="rss-category"]:checked').value;
        const url = category === 'all' 
            ? `${API_BASE}/api/rss/events?limit=100`
            : `${API_BASE}/api/rss/events?category=${category}&limit=100`;
        
        const response = await fetch(url);
        const result = await response.json();
        
        if (result.success) {
            state.rssEvents = result.data;
            renderRSSTable();
        }
    } catch (error) {
        console.error('加载RSS数据失败:', error);
    }
}

// 渲染RSS表格
function renderRSSTable() {
    const tbody = document.querySelector('#rss-table tbody');
    if (!tbody) return;
    
    tbody.innerHTML = state.rssEvents.map(e => `
        <tr>
            <td>${e.published_at ? new Date(e.published_at).toLocaleString() : '--'}</td>
            <td>${e.title}</td>
            <td>${e.category === 'political' ? '政治' : '战争'}</td>
            <td>${e.score}</td>
            <td>${e.source_name}</td>
            <td><a href="${e.link}" target="_blank">查看</a></td>
        </tr>
    `).join('');
}

// 加载系统状态
async function loadSystemStatus() {
    try {
        const response = await fetch(`${API_BASE}/api/system/status`);
        const result = await response.json();
        
        if (result.success) {
            state.systemStatus = result.data;
            renderSystemStatus();
        }
    } catch (error) {
        console.error('加载系统状态失败:', error);
    }
}

// 渲染系统状态
function renderSystemStatus() {
    const data = state.systemStatus;
    
    // 渲染健康状态
    const healthContainer = document.getElementById('health-status');
    if (healthContainer && data.health_status) {
        healthContainer.innerHTML = data.health_status.map(h => `
            <div class="status-item ${h.status}">
                <div class="status-item-name">${h.source_name}</div>
                <div class="status-item-value">状态: ${h.status}</div>
                <div class="status-item-value">错误次数: ${h.error_count}</div>
            </div>
        `).join('');
    }
    
    // 渲染调度状态
    const schedulerContainer = document.getElementById('scheduler-status');
    if (schedulerContainer && data.scheduler_status) {
        schedulerContainer.innerHTML = data.scheduler_status.map(s => `
            <div class="status-item">
                <div class="status-item-name">${s.task_name}</div>
                <div class="status-item-value">状态: ${s.status}</div>
                <div class="status-item-value">
                    最后运行: ${s.last_run_at ? new Date(s.last_run_at).toLocaleString() : '--'}
                </div>
            </div>
        `).join('');
    }
    
    // 渲染更新记录
    const updateContainer = document.getElementById('update-records');
    if (updateContainer && data.recent_updates) {
        updateContainer.innerHTML = data.recent_updates.map(u => `
            <div class="update-item">
                <div class="update-item-info">
                    <div class="update-item-type">${u.data_type}</div>
                    <div class="update-item-time">${new Date(u.created_at).toLocaleString()}</div>
                </div>
                <div class="update-item-status ${u.status}">${u.status}</div>
            </div>
        `).join('');
    }
}

// 刷新函数
function refreshSGEData() {
    loadSGEData();
}

function refreshReversalData() {
    loadReversalData();
}

function refreshUS10YData() {
    loadUS10YData();
}

function refreshRSSData() {
    loadRSSData();
}

function refreshSystemStatus() {
    loadSystemStatus();
}

// 更新最后更新时间
function updateLastUpdateTime() {
    document.getElementById('last-update').textContent = new Date().toLocaleString();
}

// 初始化自动刷新
function initAutoRefresh() {
    // 每30秒刷新一次当前视图
    setInterval(() => {
        loadViewData(state.currentView);
    }, 30000);
}

// RSS分类过滤
document.addEventListener('change', (e) => {
    if (e.target.name === 'rss-category') {
        loadRSSData();
    }
});

// 窗口大小改变时重新渲染图表
window.addEventListener('resize', () => {
    Object.values(state.charts).forEach(chart => {
        if (chart) {
            chart.resize();
        }
    });
});

// 从/api/status数据渲染SGE图表
function renderSGEChartFromStatusData(samples) {
    const chartDom = document.getElementById('sge-chart');
    if (!chartDom) return;
    
    let chart = state.charts.sgeChart;
    if (!chart) {
        chart = echarts.init(chartDom);
        state.charts.sgeChart = chart;
    }
    
    const times = samples.map(d => new Date(d.fetched_at).toLocaleTimeString());
    const premiums = samples.map(d => d.premium_cny_per_g || 0);
    const shfePrices = samples.map(d => d.shfe_price_cny_per_g || 0);
    const premiumPercents = samples.map((d, i) => 
        shfePrices[i] > 0 ? (premiums[i] / shfePrices[i] * 100) : 0
    );
    
    const option = {
        tooltip: {
            trigger: 'axis',
            axisPointer: {
                type: 'cross'
            }
        },
        legend: {
            data: ['溢价(元/克)', '溢价率(%)']
        },
        grid: {
            left: '3%',
            right: '4%',
            bottom: '3%',
            containLabel: true
        },
        xAxis: {
            type: 'category',
            boundaryGap: false,
            data: times
        },
        yAxis: [
            {
                type: 'value',
                name: '溢价(元/克)',
                position: 'left'
            },
            {
                type: 'value',
                name: '溢价率(%)',
                position: 'right'
            }
        ],
        series: [
            {
                name: '溢价(元/克)',
                type: 'line',
                data: premiums,
                smooth: true,
                lineStyle: {
                    color: '#667eea'
                },
                itemStyle: {
                    color: '#667eea'
                }
            },
            {
                name: '溢价率(%)',
                type: 'line',
                yAxisIndex: 1,
                data: premiumPercents,
                smooth: true,
                lineStyle: {
                    color: '#764ba2'
                },
                itemStyle: {
                    color: '#764ba2'
                }
            }
        ]
    };
    
    chart.setOption(option);
}

// 从/api/status数据渲染RSS事件
function renderRSSEventsFromStatusData(events) {
    const politicalContainer = document.getElementById('political-events');
    const warContainer = document.getElementById('war-events');
    
    if (!politicalContainer || !warContainer) return;
    
    const politicalEvents = events.filter(e => e.event_type === 'political');
    const warEvents = events.filter(e => e.event_type === 'war');
    
    // 渲染政治事件
    politicalContainer.innerHTML = politicalEvents.slice(0, 5).map(event => `
        <div class="event-item">
            <div class="event-header">
                <span class="event-score score-${event.impact_level}">${event.impact_score}分</span>
                <span class="event-time">${new Date(event.published_at).toLocaleString()}</span>
            </div>
            <div class="event-title">${event.title}</div>
            <div class="event-keywords">${event.matched_keywords || '无关键词'}</div>
            <div class="event-note">${event.impact_note || ''}</div>
        </div>
    `).join('');
    
    // 渲染战争事件
    warContainer.innerHTML = warEvents.slice(0, 5).map(event => `
        <div class="event-item">
            <div class="event-header">
                <span class="event-score score-${event.impact_level}">${event.impact_score}分</span>
                <span class="event-time">${new Date(event.published_at).toLocaleString()}</span>
            </div>
            <div class="event-title">${event.title}</div>
            <div class="event-keywords">${event.matched_keywords || '无关键词'}</div>
            <div class="event-note">${event.impact_note || ''}</div>
        </div>
    `).join('');
}
