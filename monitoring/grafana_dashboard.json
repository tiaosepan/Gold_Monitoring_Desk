{
  "dashboard": {
    "title": "黄金监控中台 - 系统监控仪表盘",
    "tags": ["gold", "monitoring", "trading"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "SGE采集成功率",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(sge_fetch_total{status=\"success\"}[5m]) / rate(sge_fetch_total[5m]) * 100",
            "legendFormat": "成功率 %"
          }
        ],
        "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4}
      },
      {
        "id": 2,
        "title": "SGE采集频率",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(sge_fetch_total[1m]) * 60",
            "legendFormat": "采集次数/分钟"
          }
        ],
        "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4}
      },
      {
        "id": 3,
        "title": "SGE当前溢价",
        "type": "graph",
        "targets": [
          {
            "expr": "sge_premium_cny_per_g",
            "legendFormat": "溢价（元/克）"
          }
        ],
        "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4}
      },
      {
        "id": 4,
        "title": "反转信号等级",
        "type": "graph",
        "targets": [
          {
            "expr": "reversal_signal_level",
            "legendFormat": "反转等级"
          }
        ],
        "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4}
      },
      {
        "id": 5,
        "title": "API响应时间（P95）",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(api_response_duration_seconds_bucket[5m]))",
            "legendFormat": "{{ endpoint }}"
          }
        ],
        "gridPos": {"x": 0, "y": 4, "w": 12, "h": 6}
      },
      {
        "id": 6,
        "title": "任务执行耗时对比",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(sge_fetch_duration_seconds_bucket[5m]))",
            "legendFormat": "SGE采集"
          },
          {
            "expr": "histogram_quantile(0.95, rate(reversal_detect_duration_seconds_bucket[5m]))",
            "legendFormat": "反转检测"
          },
          {
            "expr": "histogram_quantile(0.95, rate(rss_collect_duration_seconds_bucket[5m]))",
            "legendFormat": "RSS采集"
          }
        ],
        "gridPos": {"x": 12, "y": 4, "w": 12, "h": 6}
      },
      {
        "id": 7,
        "title": "RSS源状态",
        "type": "table",
        "targets": [
          {
            "expr": "rate(rss_collect_total[5m])",
            "format": "table",
            "instant": true
          }
        ],
        "gridPos": {"x": 0, "y": 10, "w": 12, "h": 6}
      },
      {
        "id": 8,
        "title": "数据源健康状态",
        "type": "stat",
        "targets": [
          {
            "expr": "data_source_health",
            "legendFormat": "{{ source_name }}"
          }
        ],
        "gridPos": {"x": 12, "y": 10, "w": 12, "h": 6}
      },
      {
        "id": 9,
        "title": "反转信号分布",
        "type": "graph",
        "targets": [
          {
            "expr": "reversal_signal_active{signal_type=\"price\"}",
            "legendFormat": "价格信号"
          },
          {
            "expr": "reversal_signal_active{signal_type=\"political\"}",
            "legendFormat": "政治信号"
          },
          {
            "expr": "reversal_signal_active{signal_type=\"war\"}",
            "legendFormat": "战争信号"
          },
          {
            "expr": "reversal_signal_active{signal_type=\"us10y\"}",
            "legendFormat": "美债信号"
          }
        ],
        "gridPos": {"x": 0, "y": 16, "w": 24, "h": 6}
      }
    ],
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    }
  }
}
